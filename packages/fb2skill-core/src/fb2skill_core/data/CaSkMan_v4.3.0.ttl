OpcUa:hasEffectEnable rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf OpcUa:hasEffect ;
                      owl:inverseOf OpcUa:mayBeEnabledBy ;
                      OpcUa:referenceType OpcUa:HasEffectEnable .


