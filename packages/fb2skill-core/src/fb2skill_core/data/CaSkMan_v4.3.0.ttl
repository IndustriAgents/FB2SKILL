###  http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type_Member
<http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type_Member> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Type> .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element
<http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element> rdf:type owl:Class ;
                                                           rdfs:subClassOf <http://www.w3id.org/hsu-aut/css#Property> ,
                                                                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#has_Instance_Description> ;
                                                                                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                    owl:onClass [ owl:intersectionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description>
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#Expression_Goal> ;
                                                                                                                                         owl:hasValue "Actual_Value"
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                                  ]
                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#has_Instance_Description> ;
                                                                                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                    owl:onClass [ owl:intersectionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description>
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#Expression_Goal> ;
                                                                                                                                         owl:hasValue "Assurance"
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                                  ]
                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#has_Instance_Description> ;
                                                                                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                    owl:onClass [ owl:intersectionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description>
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#Expression_Goal> ;
                                                                                                                                         owl:hasValue "Requirement"
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                                  ]
                                                                                                ) ;
                                                                             rdf:type owl:Class
                                                                           ] ,
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#has_Type_Description> ;
                                                                             owl:someValuesFrom <http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description>
                                                                           ] ,
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#has_Instance_Description> ;
                                                                             owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                                             owl:onClass <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description>
                                                                           ] ;
                                                           owl:disjointWith <http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description> ;
                                                           rdfs:comment """Description:
Contains a the structure of all data element (DIN61360 3.5.2, see also section 4)

Each Data_Element has to have a type description and may have an instance description""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Type
<http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Type> rdf:type owl:Class .


