OpcUa:hasModellingRule rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                       owl:inverseOf OpcUa:modellingRuleOf ;
                       OpcUa:referenceType OpcUa:HasModellingRule .


