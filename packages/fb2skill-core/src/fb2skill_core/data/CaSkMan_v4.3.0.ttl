@prefix : <http://www.w3id.org/hsu-aut/caskman#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix OpcUa: <http://www.hsu-ifa.de/ontologies/OpcUa#> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@base <http://www.w3id.org/hsu-aut/caskman#> .

<http://www.w3id.org/hsu-aut/caskman#> rdf:type owl:Ontology ;
                                        owl:versionIRI <http://www.w3id.org/hsu-aut/caskman/4.3.0#> ;
                                        rdfs:comment "A domain ontology to describe capabilities and skills. This ontology extends the concepts defined in the CSS ontology (https://github.com/hsu-aut/css-ontology) by using ontology design patterns for different standards." ,
                                                     "An ontology for the Capability, Skill and Service reference model defined by Plattform Industrie 4.0. See https://www.plattform-i40.de/IP/Redaktion/DE/Downloads/Publikation/CapabilitiesSkillsServices.html for a description of the abstract reference model." ;
                                        rdfs:isDefinedBy "ANSl/ISA-TR88.00.02-2015" ,
                                                         "https://www.plattform-i40.de/IP/Redaktion/DE/Downloads/Publikation/CapabilitiesSkillsServices.html" ;
                                        owl:versionInfo "1.0.0" ,
                                                        1.1 ,
                                                        "1.2.0" ,
                                                        "1.4.0" ,
                                                        "2.0.0" ,
                                                        "3.0.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
swrla:isRuleEnabled rdf:type owl:AnnotationProperty .


###  http://www.hsu-ifa.de/ontologies/OpcUa#objectProperty
OpcUa:objectProperty rdf:type owl:AnnotationProperty .


###  http://www.hsu-ifa.de/ontologies/OpcUa#referenceType
OpcUa:referenceType rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element_describes
<http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element_describes> rdf:type owl:ObjectProperty ;
                                                                     owl:inverseOf <http://www.hsu-ifa.de/ontologies/DINEN61360#has_Data_Element> ;
                                                                     rdfs:domain <http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element> ;
                                                                     rdfs:comment """Description:
This ObjectProperty is used to connect a data element with any kind of entity that is described by the data element""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description_has_Type
<http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description_has_Type> rdf:type owl:ObjectProperty ;
                                                                            owl:inverseOf <http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description_has_Instance> ;
                                                                            rdfs:domain <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description> ;
                                                                            rdfs:range <http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description> .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description_has_Instance
<http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description_has_Instance> rdf:type owl:ObjectProperty ;
                                                                            rdfs:domain <http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description> ;
                                                                            rdfs:range <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description> .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#complex_Data_Type_has_Member
<http://www.hsu-ifa.de/ontologies/DINEN61360#complex_Data_Type_has_Member> rdf:type owl:ObjectProperty ;
                                                                           owl:inverseOf <http://www.hsu-ifa.de/ontologies/DINEN61360#is_Member_of_Complex_Data_Type> ;
                                                                           rdfs:domain [ owl:intersectionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description>
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description_has_Type> ;
                                                                                                                owl:allValuesFrom <http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type>
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ] ;
                                                                           rdfs:range <http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type_Member> ;
                                                                           rdfs:comment """Description:
ObjectProperty that is used to connect an instance of a complex data type with corresponding members of the complex data type. These members are connected to types and instances of other (complex) data types""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#has_Data_Element
<http://www.hsu-ifa.de/ontologies/DINEN61360#has_Data_Element> rdf:type owl:ObjectProperty ;
                                                               rdfs:range <http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element> ;
                                                               rdfs:comment """Description:
This ObjectProperty is used to connect any kind of entity with a data element that is used for its description.""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#has_Instance_Description
<http://www.hsu-ifa.de/ontologies/DINEN61360#has_Instance_Description> rdf:type owl:ObjectProperty ;
                                                                       owl:inverseOf <http://www.hsu-ifa.de/ontologies/DINEN61360#is_Instance_Description_of_Data_Element> ;
                                                                       rdf:type owl:InverseFunctionalProperty ;
                                                                       rdfs:domain [ rdf:type owl:Class ;
                                                                                     owl:unionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type_Member>
                                                                                                   <http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element>
                                                                                                 )
                                                                                   ] ;
                                                                       rdfs:range <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description> ;
                                                                       rdfs:comment """Description:
ObjectProperty is used to connect an individual that needs to be described by DataProperties with the Instance Description of that properties.""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#has_Type_Description
<http://www.hsu-ifa.de/ontologies/DINEN61360#has_Type_Description> rdf:type owl:ObjectProperty ;
                                                                   owl:inverseOf <http://www.hsu-ifa.de/ontologies/DINEN61360#is_Type_Description_of_Data_Element> ;
                                                                   rdf:type owl:FunctionalProperty ;
                                                                   rdfs:domain [ rdf:type owl:Class ;
                                                                                 owl:unionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type_Member>
                                                                                               <http://www.hsu-ifa.de/ontologies/DINEN61360#Data_Element>
                                                                                             )
                                                                               ] ;
                                                                   rdfs:range <http://www.hsu-ifa.de/ontologies/DINEN61360#Type_Description> ;
                                                                   rdfs:comment """Description:
ObjectProperty is used to connect an individual that needs to be described by DataProperties with the Type Description of that properties.

Functional:
Any indivudual representing a property, can have only one Type Description""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#is_Instance_Description_of_Data_Element
<http://www.hsu-ifa.de/ontologies/DINEN61360#is_Instance_Description_of_Data_Element> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:comment """Description:
ObjectProperty is used to connect an Instance Description with the Data_Element that it describes.

Inverse of has_Instance_Description""" .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#is_Member_of_Complex_Data_Type
<http://www.hsu-ifa.de/ontologies/DINEN61360#is_Member_of_Complex_Data_Type> rdf:type owl:ObjectProperty ;
                                                                             rdfs:domain <http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type_Member> ;
                                                                             rdfs:range [ owl:intersectionOf ( <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description>
                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                 owl:onProperty <http://www.hsu-ifa.de/ontologies/DINEN61360#Instance_Description_has_Type> ;
                                                                                                                 owl:allValuesFrom <http://www.hsu-ifa.de/ontologies/DINEN61360#Complex_Data_Type>
                                                                                                               ]
                                                                                                             ) ;
                                                                                          rdf:type owl:Class
                                                                                        ] .


###  http://www.hsu-ifa.de/ontologies/DINEN61360#is_Type_Description_of_Data_Element
<http://www.hsu-ifa.de/ontologies/DINEN61360#is_Type_Description_of_Data_Element> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:comment """Description:
ObjectProperty is used to connect a Type_Description with a Data_Element that has instace descriptions of this type. 

Inverse of has_Type_Description""" .


###  http://www.hsu-ifa.de/ontologies/ISA-TR88#consistsOfState
<http://www.hsu-ifa.de/ontologies/ISA-TR88#consistsOfState> rdf:type owl:ObjectProperty ;
                                                            rdfs:domain <http://www.hsu-ifa.de/ontologies/ISA-TR88#StateMachine> ;
                                                            rdfs:range <http://www.hsu-ifa.de/ontologies/ISA-TR88#State> ;
                                                            rdfs:comment "Defines that a State is part of a State Machine." .


###  http://www.hsu-ifa.de/ontologies/ISA-TR88#consistsOfTransition
<http://www.hsu-ifa.de/ontologies/ISA-TR88#consistsOfTransition> rdf:type owl:ObjectProperty ;
                                                                 rdfs:domain <http://www.hsu-ifa.de/ontologies/ISA-TR88#StateMachine> ;
                                                                 rdfs:range <http://www.hsu-ifa.de/ontologies/ISA-TR88#Transition> ;
                                                                 rdfs:comment "Defines that a Transition is part of a State Machine." .


###  http://www.hsu-ifa.de/ontologies/ISA-TR88#hasIncomingTransition
<http://www.hsu-ifa.de/ontologies/ISA-TR88#hasIncomingTransition> rdf:type owl:ObjectProperty ;
                                                                  owl:inverseOf <http://www.hsu-ifa.de/ontologies/ISA-TR88#hasTargetState> ;
                                                                  rdfs:domain <http://www.hsu-ifa.de/ontologies/ISA-TR88#State> ;
                                                                  rdfs:range <http://www.hsu-ifa.de/ontologies/ISA-TR88#Transition> ;
                                                                  rdfs:comment "Describes the relationship between a state and it's incoming transition." .


###  http://www.hsu-ifa.de/ontologies/ISA-TR88#hasOutgoingTransition
<http://www.hsu-ifa.de/ontologies/ISA-TR88#hasOutgoingTransition> rdf:type owl:ObjectProperty ;
                                                                  owl:inverseOf <http://www.hsu-ifa.de/ontologies/ISA-TR88#hasSourceState> ;
                                                                  rdfs:domain <http://www.hsu-ifa.de/ontologies/ISA-TR88#State> ;
                                                                  rdfs:range <http://www.hsu-ifa.de/ontologies/ISA-TR88#Transition> ;
                                                                  rdfs:comment "Describes the relationship between a state and it's outgoing transition." .


###  http://www.hsu-ifa.de/ontologies/ISA-TR88#hasSourceState
<http://www.hsu-ifa.de/ontologies/ISA-TR88#hasSourceState> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <http://www.hsu-ifa.de/ontologies/ISA-TR88#Transition> ;
                                                           rdfs:range <http://www.hsu-ifa.de/ontologies/ISA-TR88#State> ;
                                                           rdfs:comment "Describes the relationship between a transition and the State it originated in." .


###  http://www.hsu-ifa.de/ontologies/ISA-TR88#hasTargetState
<http://www.hsu-ifa.de/ontologies/ISA-TR88#hasTargetState> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <http://www.hsu-ifa.de/ontologies/ISA-TR88#Transition> ;
                                                           rdfs:range <http://www.hsu-ifa.de/ontologies/ISA-TR88#State> ;
                                                           rdfs:comment "Describes the relationship between a transition and the State it ends in." .


###  http://www.hsu-ifa.de/ontologies/OpcUa#aggregatedBy
OpcUa:aggregatedBy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf OpcUa:hasChild ;
                   owl:inverseOf OpcUa:aggregates .


###  http://www.hsu-ifa.de/ontologies/OpcUa#aggregates
OpcUa:aggregates rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf OpcUa:hasChild ;
                 OpcUa:referenceType OpcUa:Aggregates .


###  http://www.hsu-ifa.de/ontologies/OpcUa#alarmGroupMember
OpcUa:alarmGroupMember rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf OpcUa:organizes ;
                       owl:inverseOf OpcUa:memberOfAlarmGroup ;
                       OpcUa:referenceType OpcUa:AlarmGroupMember .


###  http://www.hsu-ifa.de/ontologies/OpcUa#alwaysGeneratedBy
OpcUa:alwaysGeneratedBy rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf OpcUa:generatesEvent ;
                        owl:inverseOf OpcUa:alwaysGeneratesEvent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#alwaysGeneratesEvent
OpcUa:alwaysGeneratesEvent rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf OpcUa:generatesEvent ;
                           OpcUa:referenceType OpcUa:AlwaysGeneratesEvent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#childOf
OpcUa:childOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf OpcUa:hierarchicalReferences ;
              owl:inverseOf OpcUa:hasChild .


###  http://www.hsu-ifa.de/ontologies/OpcUa#componentOf
OpcUa:componentOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf OpcUa:aggregates ;
                  owl:inverseOf OpcUa:hasComponent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#containsNode
OpcUa:containsNode rdf:type owl:ObjectProperty ;
                   rdfs:domain OpcUa:UANodeSet ;
                   rdfs:range OpcUa:UANode .


###  http://www.hsu-ifa.de/ontologies/OpcUa#dataSetToWriter
OpcUa:dataSetToWriter rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf OpcUa:hierarchicalReferences ;
                      owl:inverseOf OpcUa:writerToDataSet ;
                      OpcUa:referenceType OpcUa:DataSetToWriter .


###  http://www.hsu-ifa.de/ontologies/OpcUa#descriptionOf
OpcUa:descriptionOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                    owl:inverseOf OpcUa:hasDescription .


###  http://www.hsu-ifa.de/ontologies/OpcUa#encodingOf
OpcUa:encodingOf rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                 owl:inverseOf OpcUa:hasEncoding .


###  http://www.hsu-ifa.de/ontologies/OpcUa#eventSourceOf
OpcUa:eventSourceOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf OpcUa:hierarchicalReferences ;
                    owl:inverseOf OpcUa:hasEventSource .


###  http://www.hsu-ifa.de/ontologies/OpcUa#firstMethodArgument
OpcUa:firstMethodArgument rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf OpcUa:hasMethodArgument ;
                          rdfs:range OpcUa:UAMethodArgument .


###  http://www.hsu-ifa.de/ontologies/OpcUa#firstValue
OpcUa:firstValue rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf OpcUa:hasValue ;
                 rdfs:range OpcUa:UAValue .


###  http://www.hsu-ifa.de/ontologies/OpcUa#fromState
OpcUa:fromState rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                owl:inverseOf OpcUa:toTransition ;
                OpcUa:referenceType OpcUa:FromState .


###  http://www.hsu-ifa.de/ontologies/OpcUa#fromTransition
OpcUa:fromTransition rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                     owl:inverseOf OpcUa:toState .


###  http://www.hsu-ifa.de/ontologies/OpcUa#generatedBy
OpcUa:generatedBy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                  owl:inverseOf OpcUa:generatesEvent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#generatesEvent
OpcUa:generatesEvent rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                     OpcUa:referenceType OpcUa:GeneratesEvent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasAlarmSuppressionGroup
OpcUa:hasAlarmSuppressionGroup rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf OpcUa:hasComponent ;
                               owl:inverseOf OpcUa:isAlarmSuppressionGroupOf ;
                               OpcUa:referenceType OpcUa:HasAlarmSuppressionGroup .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasCause
OpcUa:hasCause rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
               owl:inverseOf OpcUa:mayBeCausedBy ;
               OpcUa:referenceType OpcUa:HasCause .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasChild
OpcUa:hasChild rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf OpcUa:hierarchicalReferences ;
               OpcUa:referenceType OpcUa:HasChild .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasComponent
OpcUa:hasComponent rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf OpcUa:aggregates ;
                   OpcUa:referenceType OpcUa:HasComponent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasCondition
OpcUa:hasCondition rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                   owl:inverseOf OpcUa:isConditionOf ;
                   OpcUa:referenceType OpcUa:HasCondition .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasDataSetReader
OpcUa:hasDataSetReader rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf OpcUa:hasComponent ;
                       owl:inverseOf OpcUa:isReaderInGroup ;
                       OpcUa:referenceType OpcUa:HasDataSetReader .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasDataSetWriter
OpcUa:hasDataSetWriter rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf OpcUa:hasComponent ;
                       owl:inverseOf OpcUa:isWriterInGroup ;
                       OpcUa:referenceType OpcUa:HasDataSetWriter .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasDataType
OpcUa:hasDataType rdf:type owl:ObjectProperty ;
                  rdfs:range OpcUa:UADataType .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasDataTypeDefinition
OpcUa:hasDataTypeDefinition rdf:type owl:ObjectProperty ;
                            rdfs:range OpcUa:UADataTypeDefinition .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasDataTypeField
OpcUa:hasDataTypeField rdf:type owl:ObjectProperty ;
                       rdfs:range OpcUa:UADataTypeField .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasDescription
OpcUa:hasDescription rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                     OpcUa:referenceType OpcUa:HasDescription .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasEffect
OpcUa:hasEffect rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                owl:inverseOf OpcUa:mayBeEffectedBy ;
                OpcUa:referenceType OpcUa:HasEffect .


