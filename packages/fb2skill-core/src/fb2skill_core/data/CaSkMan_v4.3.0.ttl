OpcUa:hasNotifier rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf OpcUa:hasEventSource ;
                  owl:inverseOf OpcUa:notifierOf ;
                  OpcUa:referenceType OpcUa:HasNotifier .


