                                                        owl:propertyChainAxiom ( <http://www.hsu-ifa.de/ontologies/VDI3682#hasOutput>
                                                                                 [ owl:inverseOf <http://www.hsu-ifa.de/ontologies/VDI3682#hasInput>
                                                                                 ]
                                                                               ) ;
                                                        rdfs:comment "an object property that is used to infer a successing relationshipt between entities" .


###  http://www.hsu-ifa.de/ontologies/VDI3682#hasUpperProcess
<http://www.hsu-ifa.de/ontologies/VDI3682#hasUpperProcess> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain [ rdf:type owl:Class ;
                                                                         owl:unionOf ( <http://www.hsu-ifa.de/ontologies/VDI3682#Process>
