OpcUa:hasEffectSuppressed rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf OpcUa:hasEffect ;
                          owl:inverseOf OpcUa:mayBeSuppressedBy ;
                          OpcUa:referenceType OpcUa:HasEffectSuppressed .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasEffectUnsuppressed
OpcUa:hasEffectUnsuppressed rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf OpcUa:hasEffect ;
                            owl:inverseOf OpcUa:mayBeUnsuppressedBy ;
                            OpcUa:referenceType OpcUa:HasEffectUnsuppressed .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasEncoding
OpcUa:hasEncoding rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
                  OpcUa:referenceType OpcUa:HasEncoding .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasEventSource
OpcUa:hasEventSource rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf OpcUa:hierarchicalReferences ;
                     OpcUa:referenceType OpcUa:HasEventSource .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasExtType
OpcUa:hasExtType rdf:type owl:ObjectProperty ;
                 rdfs:domain OpcUa:UAValue .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasFalseSubState
OpcUa:hasFalseSubState rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf OpcUa:nonHierarchicalReferences ;
