###  http://www.hsu-ifa.de/ontologies/VDI2206#Actuator
<http://www.hsu-ifa.de/ontologies/VDI2206#Actuator> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2206#Component> ;
                                                    rdfs:comment "The information processing determines the effects necessary to influence the state variables of the basic system in the desired way. The implementation of the effects takes place by actors directly on the basic system." .


###  http://www.hsu-ifa.de/ontologies/VDI2206#BasicSystem
<http://www.hsu-ifa.de/ontologies/VDI2206#BasicSystem> rdf:type owl:Class ;
                                                       rdfs:comment "The basic system is generally a mechanical, electromechanical, hydraulic or pneumatic structure or a combination of these." ;
                                                       rdfs:label "Basic System" .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Component
<http://www.hsu-ifa.de/ontologies/VDI2206#Component> rdf:type owl:Class .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Energy
<http://www.hsu-ifa.de/ontologies/VDI2206#Energy> rdf:type owl:Class ;
                                                  owl:equivalentClass <http://www.hsu-ifa.de/ontologies/VDI3682#Energy> ;
                                                  rdfs:comment "Energy is to be understood in this connection as meaning any form of energy, such as for example mechanical, thermal or electrical energy, but also variables such as force or current." .


###  http://www.hsu-ifa.de/ontologies/VDI2206#EnergyInterface
<http://www.hsu-ifa.de/ontologies/VDI2206#EnergyInterface> rdf:type owl:Class ;
                                                           rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2206#Interface> .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Information
<http://www.hsu-ifa.de/ontologies/VDI2206#Information> rdf:type owl:Class ;
                                                       owl:equivalentClass <http://www.hsu-ifa.de/ontologies/VDI3682#Information> ;
                                                       rdfs:comment "Information exchanged between units of mechatronic systems are for example measured variables, control pulses or data" .


###  http://www.hsu-ifa.de/ontologies/VDI2206#InformationInterface
<http://www.hsu-ifa.de/ontologies/VDI2206#InformationInterface> rdf:type owl:Class ;
                                                                rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2206#Interface> .


###  http://www.hsu-ifa.de/ontologies/VDI2206#InformationProcessing
<http://www.hsu-ifa.de/ontologies/VDI2206#InformationProcessing> rdf:type owl:Class ;
                                                                 rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2206#Component> .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Interface
<http://www.hsu-ifa.de/ontologies/VDI2206#Interface> rdf:type owl:Class ;
                                                     owl:disjointWith [ rdf:type owl:Class ;
                                                                        owl:unionOf ( <http://www.hsu-ifa.de/ontologies/VDI2206#BasicSystem>
                                                                                      <http://www.hsu-ifa.de/ontologies/VDI2206#Energy>
                                                                                      <http://www.hsu-ifa.de/ontologies/VDI2206#Information>
                                                                                      <http://www.hsu-ifa.de/ontologies/VDI2206#Module>
                                                                                      <http://www.hsu-ifa.de/ontologies/VDI2206#Product>
                                                                                      <http://www.hsu-ifa.de/ontologies/VDI2206#System>
                                                                                    )
                                                                      ] .


###  http://www.hsu-ifa.de/ontologies/VDI2206#MechanicalInterface
<http://www.hsu-ifa.de/ontologies/VDI2206#MechanicalInterface> rdf:type owl:Class ;
                                                               rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2206#Interface> .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Module
<http://www.hsu-ifa.de/ontologies/VDI2206#Module> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI3682#TechnicalResource> ;
                                                  rdfs:comment "Complex mechatronic systems generally comprise the synergetic integration of various mechatronic modules, i.e. system elements or components which are combined to form a group and together perform a specific function." ;
                                                  rdfs:label "Module" .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Product
<http://www.hsu-ifa.de/ontologies/VDI2206#Product> rdf:type owl:Class ;
                                                   owl:equivalentClass <http://www.hsu-ifa.de/ontologies/VDI3682#Product> ,
                                                                       <http://www.w3id.org/hsu-aut/css#Product> ;
                                                   rdfs:comment "Examples of materials which flow between units of mechatronic systems are solid bodies, objects under test, objects being treated, gases or liquids." .


###  http://www.hsu-ifa.de/ontologies/VDI2206#Sensor
<http://www.hsu-ifa.de/ontologies/VDI2206#Sensor> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2206#Component> ;
                                                  rdfs:comment "The task of the sensors is to determine selected state variables of the basic system." .


###  http://www.hsu-ifa.de/ontologies/VDI2206#System
<http://www.hsu-ifa.de/ontologies/VDI2206#System> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI3682#TechnicalResource> ;
                                                  rdfs:label "Mechatronic System" .


###  http://www.hsu-ifa.de/ontologies/VDI2860#Abteilen
<http://www.hsu-ifa.de/ontologies/VDI2860#Abteilen> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2860#MengenVeraendern> ;
                                                    rdfs:label "Abteilen"@de ,
                                                               "Separating"@en .


###  http://www.hsu-ifa.de/ontologies/VDI2860#AnwesenheitPruefen
<http://www.hsu-ifa.de/ontologies/VDI2860#AnwesenheitPruefen> rdf:type owl:Class ;
                                                              rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2860#Pruefen> ;
                                                              rdfs:label "AnalyzingPresence"@en ,
                                                                         "AnwesenheitPruefen"@de .


###  http://www.hsu-ifa.de/ontologies/VDI2860#Bewegen
<http://www.hsu-ifa.de/ontologies/VDI2860#Bewegen> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2860#Handhaben> ;
                                                   rdfs:label "Bewegen"@de ,
                                                              "Moving"@en .


###  http://www.hsu-ifa.de/ontologies/VDI2860#Drehen
<http://www.hsu-ifa.de/ontologies/VDI2860#Drehen> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2860#Bewegen> ;
                                                  rdfs:label "Drehen"@de ,
                                                             "Rotating"@en .


###  http://www.hsu-ifa.de/ontologies/VDI2860#Entspannen
<http://www.hsu-ifa.de/ontologies/VDI2860#Entspannen> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2860#Loesen> ;
                                                      rdfs:label "Entspannen"@de ,
                                                                 "Slackening"@en .


###  http://www.hsu-ifa.de/ontologies/VDI2860#FarbePruefen
<http://www.hsu-ifa.de/ontologies/VDI2860#FarbePruefen> rdf:type owl:Class ;
                                                        rdfs:subClassOf <http://www.hsu-ifa.de/ontologies/VDI2860#Pruefen> ;
                                                        rdfs:label "AnalyzingColor"@en ,
