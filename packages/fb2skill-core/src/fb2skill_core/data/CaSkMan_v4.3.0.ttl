OpcUa:hasHistoricalConfiguration rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf OpcUa:aggregates ;
                                 owl:inverseOf OpcUa:historicalConfigurationOf ;
                                 OpcUa:referenceType OpcUa:HasHistoricalConfiguration .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasMessageSecurityMode
OpcUa:hasMessageSecurityMode rdf:type owl:ObjectProperty ;
                             rdfs:domain OpcUa:UAServer ;
                             rdfs:range OpcUa:MessageSecurityMode .


