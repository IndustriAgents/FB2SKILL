OpcUa:hasEffectDisable rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf OpcUa:hasEffect ;
                       owl:inverseOf OpcUa:mayBeDisabledBy ;
                       OpcUa:referenceType OpcUa:HasEffectDisable .


