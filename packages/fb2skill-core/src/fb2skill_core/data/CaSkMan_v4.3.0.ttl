                                                          rdf:type owl:TransitiveProperty ;
                                                          rdfs:domain <http://www.hsu-ifa.de/ontologies/VDI3682#ProcessOperator> ;
                                                          rdfs:range <http://www.hsu-ifa.de/ontologies/VDI3682#ProcessOperator> ;
                                                          owl:propertyChainAxiom ( <http://www.hsu-ifa.de/ontologies/VDI3682#hasInput>
                                                                                   [ owl:inverseOf <http://www.hsu-ifa.de/ontologies/VDI3682#hasOutput>
                                                                                   ]
                                                                                 ) ;
                                                          rdfs:comment "an object property that is used to infer a predecessing relationship between entities" .


###  http://www.hsu-ifa.de/ontologies/VDI3682#hasSubProcess
<http://www.hsu-ifa.de/ontologies/VDI3682#hasSubProcess> rdf:type owl:ObjectProperty ,
                                                                  owl:TransitiveProperty ;
                                                         rdfs:domain [ rdf:type owl:Class ;
                                                                       owl:unionOf ( <http://www.hsu-ifa.de/ontologies/VDI3682#Process>
                                                                                     <http://www.hsu-ifa.de/ontologies/VDI3682#ProcessOperator>
                                                                                   )
                                                                     ] ;
                                                         rdfs:range <http://www.hsu-ifa.de/ontologies/VDI3682#Process> ;
                                                         owl:propertyChainAxiom ( <http://www.hsu-ifa.de/ontologies/VDI3682#isComposedOf>
                                                                                  [ owl:inverseOf <http://www.hsu-ifa.de/ontologies/VDI3682#consistsOf>
                                                                                  ]
                                                                                ) ;
                                                         rdfs:comment "Is used to find the complete decomposed process of a process operatore. Note: This is syntactic sugar as a subprocess can be found by following \"isComposedOf\" and the inverse of \"consistsOf\"." .


###  http://www.hsu-ifa.de/ontologies/VDI3682#hasSuccessor
