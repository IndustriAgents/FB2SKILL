OpcUa:hasOrderedComponent rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf OpcUa:hasComponent ;
                          owl:inverseOf OpcUa:orderedComponentOf ;
                          OpcUa:referenceType OpcUa:HasOrderedComponent .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasParent
OpcUa:hasParent rdf:type owl:ObjectProperty ;
                rdfs:domain OpcUa:UANode ;
                rdfs:range OpcUa:UANode .


###  http://www.hsu-ifa.de/ontologies/OpcUa#hasProperty
OpcUa:hasProperty rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf OpcUa:aggregates ;
