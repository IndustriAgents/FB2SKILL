# =============================================================================
# skTransfer.ttl
# -----------------------------------------------------------------------------
# Capability & Skill description of the IEC 61499 "skTransfer" application,
# deployed on the Schneider Electric soft dPAC (SE.DPAC#Soft_dPAC, PLC1).
#
# Generated from:
#   - IEC 61499 project : d:\FESTO_DS_skills\IEC61499  (skTransfer.fbt / BasicSKILL / SKILL_BFB)
#   - OPC UA node set   : System.PLC1.opcua.xml  (UAObject "skTransfer")
#
# The skTransfer function block exposes its main skill interface as "Skill_Head"
# (a BasicSKILL / SKILL_BFB instance); its ISA-88 / PackML state machine is
# driven by writing an INT command to SKILL_CMD and observed by reading the INT
# CURRENT_STATE variable. (skTransfer also contains the sub-skills GTL2, GTR2,
# Pick2 and Place2 - internal orchestration, not modelled as separate skills.)
#
# OPC UA server : opc.tcp://host.docker.internal:4840  (SecurityPolicy None,
#                 Anonymous). The soft dPAC OPC UA server runs on the Windows
#                 host (advertised as opc.tcp://LTU-83334:4840); the CaSkade-MES
#                 backend runs in Docker and reaches the host via
#                 host.docker.internal.
# Namespace ns=2: http://se.com/EcostruxureSystemExpert
#                 (declared as index 1 in System.PLC1.opcua.xml, but the running
#                  server resolves it to index 2 - index 1 is the server's own)
#
# Modelled as a CaSkMan:OpcUaVariableSkillInterface so that the CaSkade-MES
# OpcUaVariableSkillExecutor fires transitions by writing the command value.
#
# SKILL_CMD command values : Start=1 Reset=2 Hold=3 Unhold=4 Suspend=5
#                            Unsuspend=6 Clear=7 Stop=8 Abort=9
# CURRENT_STATE values     : Idle=1 Starting=2 Execute=3 Completing=4 Complete=5
#                            Resetting=6 Holding=7 Held=8 Unholding=9
#                            Suspending=10 Suspended=11 Unsuspending=12
#                            Stopping=13 Stopped=14 Aborting=15 Aborted=16
#                            Clearing=17
# =============================================================================

@prefix :            <http://www.ltu.se/aut/ontologies/FESTO_DS_skills#> .
@prefix CSS:         <http://www.w3id.org/hsu-aut/css#> .
@prefix CaSk:        <http://www.w3id.org/hsu-aut/cask#> .
@prefix CaSkMan:     <http://www.w3id.org/hsu-aut/caskman#> .
@prefix OpcUa:       <http://www.w3id.org/hsu-aut/OpcUa#> .
@prefix ISA88:       <http://www.hsu-ifa.de/ontologies/ISA-TR88#> .
@prefix DINEN61360:  <http://www.w3id.org/hsu-aut/DINEN61360#> .
@prefix VDI3682:     <http://www.w3id.org/hsu-aut/VDI3682#> .
@prefix owl:         <http://www.w3.org/2002/07/owl#> .
@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .


# =============================================================================
# Resource, Capability and Skill
# =============================================================================

:soft_dPAC_PLC1 a CSS:Resource , owl:NamedIndividual ;
    CSS:providesCapability :skTransfer_Capability ;
    CSS:providesSkill :skTransfer .

:skTransfer_Capability a CaSk:ProvidedCapability , CSS:Capability , owl:NamedIndividual ;
    CSS:isRealizedBySkill :skTransfer .

# A VDI 3682 process operator that requires the capability. The CaSkade-MES
# capability query only returns capabilities required by a ProcessOperator,
# so this link is needed for the skill to register cleanly.
:skTransfer_Process a VDI3682:ProcessOperator , owl:NamedIndividual ;
    CSS:requiresCapability :skTransfer_Capability .

:skTransfer a CSS:Skill , CaSkMan:PlcSkill , owl:NamedIndividual ;
    CSS:behaviorConformsTo :skTransfer_StateMachine ;
    CSS:accessibleThrough :skTransfer_Interface ;
    CaSkMan:accessibleThroughOpcUaVariableInterface :skTransfer_Interface ;
    CaSk:hasCurrentState :skTransfer_StateMachine_Idle ;
    CaSk:hasCurrentStateOutput :skTransfer_CurrentStateOutput ;
    CaSk:hasSkillCommand :skTransfer_SkillCommand ;
    CaSk:hasSkillOutput :skTransfer_CurrentStateOutput , :skTransfer_SkillOutput_OUT1 ;
    CSS:hasParameter :skTransfer_SkillParameter_IN1 .


# =============================================================================
# Skill interface (OPC UA variable interface)
# =============================================================================

:skTransfer_Interface a CaSkMan:OpcUaVariableSkillInterface , CSS:SkillInterface , owl:NamedIndividual ;
    OpcUa:nodeId "ns=2;g=308d6e7d-5dd7-0a92-c11e-6cb736c2bd26" ;
    OpcUa:nodeNamespace "2" ;
    CaSk:exposesStateMachine :skTransfer_StateMachine ;
    CaSk:exposesSkillParameter :skTransfer_SkillCommand ,
        :skTransfer_SkillParameter_IN1 ,
        :skTransfer_SkillOutput_OUT1 ;
    OpcUa:organizes :skTransfer_SkillCommand ,
        :skTransfer_CurrentStateOutput ,
        :skTransfer_SkillParameter_IN1 ,
        :skTransfer_SkillOutput_OUT1 .


# =============================================================================
# OPC UA server, node set and endpoint
# =============================================================================

:skTransfer_OPCUAServer a OpcUa:UAServer , owl:NamedIndividual ;
    OpcUa:hasNodeSet :skTransfer_OPCUANodeSet ;
    OpcUa:hasEndpointDescription :skTransfer_OPCUAServer_Endpoint .

:skTransfer_OPCUANodeSet a OpcUa:UANodeSet , owl:NamedIndividual ;
    OpcUa:containsNode :skTransfer_Interface ,
        :skTransfer_SkillCommand ,
        :skTransfer_CurrentStateOutput ,
        :skTransfer_SkillParameter_IN1 ,
        :skTransfer_SkillOutput_OUT1 ;
    OpcUa:organizes :skTransfer_Interface ,
        :skTransfer_SkillCommand ,
        :skTransfer_CurrentStateOutput ,
        :skTransfer_SkillParameter_IN1 ,
        :skTransfer_SkillOutput_OUT1 .

:skTransfer_OPCUAServer_Endpoint a OpcUa:EndpointDescription , owl:NamedIndividual ;
    OpcUa:hasEndpointUrl "opc.tcp://host.docker.internal:4840" ;
    OpcUa:hasMessageSecurityMode OpcUa:MessageSecurityMode_None ;
    OpcUa:hasSecurityPolicy OpcUa:SecurityPolicy_None ;
    OpcUa:hasUserIdentityToken :skTransfer_OPCUAServer_Endpoint_UserIdentityToken .

:skTransfer_OPCUAServer_Endpoint_UserIdentityToken a OpcUa:AnonymousIdentityToken , OpcUa:UserIdentityToken , owl:NamedIndividual ;
    OpcUa:requiresUserName "" ;
    OpcUa:requiresPassword "" .

# The CaSkade-MES backend resolves the server endpoint with a query that joins on
#   ?tokenType rdfs:subClassOf OpcUa:UserIdentityToken
# That subclass axiom belongs to the OPC UA ontology. It is asserted here so the
# skill resolves its endpoint even when that ontology is not imported into
# GraphDB - otherwise the query returns no rows and the backend crashes.
OpcUa:AnonymousIdentityToken rdfs:subClassOf OpcUa:UserIdentityToken .


